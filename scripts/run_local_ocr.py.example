#!/usr/bin/env python3
"""Example shell OCR adapter for ScribeBase.

Replace the placeholder body with a call to your local OCR runtime, then configure:

ocr:
  providers:
    shell:
      command: "python ./scripts/run_local_ocr.py --input {input_image} --output {output_md}"
"""

from __future__ import annotations

import argparse
from pathlib import Path


def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("--input", required=True)
    parser.add_argument("--output", required=True)
    args = parser.parse_args()

    image = Path(args.input)
    output = Path(args.output)
    output.parent.mkdir(parents=True, exist_ok=True)

    # Replace this with GLM-OCR, PaddleOCR-VL, Chandra, Surya, etc.
    output.write_text(f"# OCR placeholder\n\nImage: {image}\n\nReplace scripts/run_local_ocr.py with a real local OCR adapter.\n")


if __name__ == "__main__":
    main()
