# Optional ScribeBase runtime overrides.
# Copy to .env on the Mac mini or export these before running commands.

# Directory for config, source files, chunks, logs, and outputs.
SCRIBEBASE_DATA_DIR=.study_local

# Optional explicit config file path. If unset, ScribeBase uses
# $SCRIBEBASE_DATA_DIR/config.yaml.
# SCRIBEBASE_CONFIG=/Users/ramtin/scribebase/config.yaml

# Future HTTP server defaults. These are read into config now so the
# server PR can use the same settings without another migration.
SCRIBEBASE_HOST=127.0.0.1
SCRIBEBASE_PORT=8765

# Shared secret for the future HTTP API. Leave unset until server mode exists.
# SCRIBEBASE_API_TOKEN=change-me
